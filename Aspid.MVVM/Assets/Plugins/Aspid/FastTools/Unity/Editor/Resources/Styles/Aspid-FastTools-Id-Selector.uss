.aspid-fasttools-id-selector-container {
    padding: 4px;
    flex-grow: 1;
    flex-direction: column;
}

.aspid-fasttools-id-selector-item
{
    height: 22px;
    padding-left: 6px;
    padding-right: 6px;
    flex-direction: row;
    align-items: center;
}

.aspid-fasttools-id-selector-item-name
{
    flex-grow: 1;
    flex-shrink: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    -unity-text-align: middle-left;
}

.aspid-fasttools-id-selector-item-id
{
    flex-shrink: 0;
    margin-left: 8px;
    color: #808080;
    font-size: 11px;
    -unity-text-align: middle-right;
}

ToolbarSearchField {
    width: auto;
    margin: 5px 0;
    padding-right: 4px;
}
