:root {
    --aspid-colors-shade-light: #C0C0C0;
    --aspid-colors-shade-hover-light: #e1e1e1;

    --aspid-fasttools-icons-open_button: resource("Icons/open_button_icon");

    align-items: center;
    flex-direction: row;
}

.aspid-fasttools-draw-adapter--margin {
    margin: 1px -2px 1px 3px;
}

Label {
    flex-grow: 1;
    flex-shrink: 1;
    min-width: 120px;
    overflow: hidden;
    text-overflow: ellipsis;
}

.aspid-fasttools-serializable-type-buttons {
    width: 60%;
    max-width: 60%;
    flex-grow: 1;
    flex-shrink: 1;
    flex-direction: row;
}

.aspid-fasttools-serializable-type-buttons.aspid-fasttools-serializable-type-only-buttons {
    width: 100%;
    max-width: 100%;
}

Button {
    margin: 0;
    flex-grow: 1;
    flex-shrink: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    -unity-text-align: middle-left;
}

.aspid-fasttools-serializable-type-open-button {
    padding: 3px;
    flex-grow: 0;
    flex-shrink: 0;
    margin-left: 1px;
    min-width: 20px;
    max-width: 20px;
    min-height: 20px;
    max-height: 20px;
}

.aspid-fasttools-serializable-type-open-button > VisualElement {
    width: 100%;
    height: 100%;
    background-image: var(--aspid-fasttools-icons-open_button);
    -unity-background-image-tint-color: var(--aspid-colors-shade-light);
}

.aspid-fasttools-serializable-type-open-button > VisualElement :hover {
    -unity-background-image-tint-color: var(--aspid-colors-shade-hover-light);
}
