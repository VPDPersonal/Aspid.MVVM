<ui:UXML xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" editor-extension-mode="True">
    <Style src="project://database/Assets/Plugins/Aspid/FastTools/Unity/Editor/Resources/UI/Aspid-FastTools-Default-Dark.uss?fileID=7433441132597879392&amp;guid=a58072b37b804991bbb887d0fd65e2f8&amp;type=3#Aspid-FastTools-Default-Dark"/>
    <Style src="project://database/Assets/Plugins/Aspid/FastTools/Unity/Editor/Resources/UI/Windows/Welcome/Aspid-FastTools-Welcome.uss?fileID=7433441132597879392&amp;guid=74929072ccf9442f6a07a76964c94928&amp;type=3#Aspid-FastTools-Welcome"/>
    <Aspid.FastTools.UIElements.Editors.Internal.AspidAnimatedDotsBackground/>
    <ui:VisualElement name="welcome-content" class="aspid-fasttools-welcome__content">
        <ui:ScrollView name="welcome-scroll" class="aspid-fasttools-welcome__scroll">
            <ui:VisualElement name="welcome-hero" class="aspid-fasttools-welcome__hero">
                <Aspid.FastTools.UIElements.Editors.Internal.AspidAnimatedLogo name="welcome-logo" image-1="project://database/Assets/Plugins/Aspid/Internal/Unity/Editor/Resources/aspid_icon_medium_green_1020x1008.png?fileID=2800000&amp;guid=2d380e9402a9f4c5b8eb637f9f40c400&amp;type=3#aspid_icon_medium_green_1020x1008" image-2="project://database/Assets/Plugins/Aspid/Internal/Unity/Editor/Resources/aspid_icon_medium_yellow_1020x1008.png?fileID=2800000&amp;guid=45e1e8af6ec4a47f192980d99bf0dbb9&amp;type=3#aspid_icon_medium_yellow_1020x1008" image-3="project://database/Assets/Plugins/Aspid/Internal/Unity/Editor/Resources/aspid_icon_medium_red_1020x1008.png?fileID=2800000&amp;guid=ec5938e9935444547813083d1e9c6392&amp;type=3#aspid_icon_medium_red_1020x1008" image1="project://database/Assets/Plugins/Aspid/Internal/Unity/Editor/Resources/aspid_icon_medium_green_1020x1008.png?fileID=2800000&amp;guid=2d380e9402a9f4c5b8eb637f9f40c400&amp;type=3#aspid_icon_medium_green_1020x1008" image2="project://database/Assets/Plugins/Aspid/Internal/Unity/Editor/Resources/aspid_icon_medium_yellow_1020x1008.png?fileID=2800000&amp;guid=45e1e8af6ec4a47f192980d99bf0dbb9&amp;type=3#aspid_icon_medium_yellow_1020x1008" image3="project://database/Assets/Plugins/Aspid/Internal/Unity/Editor/Resources/aspid_icon_medium_red_1020x1008.png?fileID=2800000&amp;guid=ec5938e9935444547813083d1e9c6392&amp;type=3#aspid_icon_medium_red_1020x1008" class="aspid-fasttools-welcome__logo"/>
                <ui:VisualElement class="aspid-fasttools-welcome__hero-text">
                    <Aspid.FastTools.UIElements.Editors.Internal.AspidAnimatedTitle text="Welcome to Aspid.FastTools"/>
                    <Aspid.FastTools.UIElements.Editors.Internal.AspidLabel text="A compact toolkit for reducing routine Unity code and editor setup. Typed selectors, enum helpers, string ID tooling, profiler markers, SerializedProperty utilities, IMGUI scopes, and UIElements extensions." label-font-style="Normal" label-theme="Light" line-size="None" selectable="true" class="aspid-fasttools-welcome__description"/>
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="welcome-samples" class="aspid-fasttools-welcome__card">
                <Aspid.FastTools.UIElements.Editors.Internal.AspidLabel text="Samples" name="" label-theme="Lightness" label-size="H2" line-theme="Dark" line-status="Success" class="aspid-fasttools-welcome__card-header"/>
                <ui:VisualElement name="welcome-samples-list"/>
            </ui:VisualElement>
        </ui:ScrollView>
        <ui:Label name="welcome-toast" class="aspid-fasttools-welcome__toast"/>
        <ui:VisualElement name="welcome-footer" style="margin-top: 2px;">
            <Aspid.FastTools.UIElements.Editors.Internal.AspidDividingLine theme="Darkness"/>
            <ui:VisualElement style="flex-grow: 1; flex-direction: row; justify-content: space-between; margin-top: 5px; padding-left: 10px; padding-right: 10px;">
                <ui:Label name="welcome-version" text="v1.0.0" class="aspid-fasttools-welcome__footer-version"/>
                <ui:Label name="welcome-github" text="GitHub" class="aspid-fasttools-welcome__footer-link"/>
            </ui:VisualElement>
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
